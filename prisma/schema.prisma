// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User with authentication
model User {
  id              String    @id @default(cuid())
  clerkId         String    @unique
  email           String    @unique
  username        String?
  profileImage    String?
  displayName     String?
  passwordHash    String?   // Added for secure custom auth storage
  isAdmin         Boolean   @default(false) // Added for admin privileges

  // Onboarding
  primarySkill    String?
  weeklyHours     Int?
  incomeGoal      Int?      @default(5000)

  // Stats & Gamification
  xp              Int       @default(0)
  level           Int       @default(1)
  levelTitle      String    @default("Hustler")
  streakDays      Int       @default(0)
  longestStreak   Int       @default(0)
  lastActive      DateTime? @default(now())
  totalIncome     Float     @default(0)

  // Referrals
  referralCode    String    @unique
  referredById    String?
  referredBy      User?     @relation("ReferralRelation", fields: [referredById], references: [id])
  referrals       User[]    @relation("ReferralRelation")
  referralBonuses ReferralBonus[]
  
  // Subscription
  subscription    Subscription?
  subscriptionId  String?
  
  // Preferences
  preferences     UserPreferences?
  
  // Content & Progress
  savedPrompts     SavedPrompt[]
  savedResources   SavedResource[]
  completedModules CompletedModule[]
  playbookProgress PlaybookProgress[]
  promptUsage      PromptUsage[]

  // Community
  communityProfile CommunityProfile?
  messages        Message[]
  achievements    UserAchievement[]
  incomeEntries   IncomeEntry[]
  aiConversations AIConversation[]

  // Bookmarks & favorites
  favoriteHustles String[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserPreferences {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  emailNotifications Boolean @default(true)
  pushNotifications Boolean @default(true)
  weeklyDigest Boolean @default(true)
  communityEmails Boolean @default(true)
  
  theme         String    @default("dark")
  locale        String    @default("en")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Subscription Management
model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  paymentProvider String?   @default("manual_wallet")
  paymentId       String?   @unique
  tier            String    @default("free") // free, starter, pro, elite
  
  status        String    @default("active") // active, pending_verification, canceled, expired
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  expiresAt     DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Content: Playbooks
model Playbook {
  id                String    @id @default(cuid())
  title             String
  description       String    @db.Text
  slug              String    @unique
  
  icon              String?
  category          String
  difficulty        String    @default("Beginner") // Beginner, Intermediate, Advanced
  
  incomeRange       String?   // "$500-1000/mo"
  timeCommitment    String?   // "5 hrs/week"
  timeToFirstIncome String?   // "14 days"
  
  content           String    @db.Text
  steps             PlaybookStep[]
  tools             String[]
  
  order             Int       @default(0)
  published         Boolean   @default(false)
  tier              String    @default("starter") // starter, pro, elite
  
  views             Int       @default(0)
  saved             Int       @default(0)
  
  progress          PlaybookProgress[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model PlaybookStep {
  id          String   @id @default(cuid())
  playbookId  String
  playbook    Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  
  title       String
  content     String   @db.Text
  order       Int
  videoUrl    String?
  checklist   Json?    // Array of string tasks
  
  createdAt   DateTime @default(now())
}

model PlaybookProgress {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbookId     String
  playbook       Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  completedSteps Int      @default(0)
  isCompleted    Boolean  @default(false)

  updatedAt      DateTime @updatedAt

  @@unique([userId, playbookId])
}

// Content: Prompts
model PromptPack {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  category      String

  prompts       Prompt[]
  
  tier          String    @default("starter")
  month         Int?
  year          Int?
  
  published     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Prompt {
  id            String    @id @default(cuid())
  packId        String
  pack          PromptPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  title         String
  content       String    @db.Text
  category      String    // copywriting, video, marketing, automation, etc.
  
  tags          String[]
  useCase       String?
  useCount      Int       @default(0)
  rating        Float     @default(0)
  
  savedBy       SavedPrompt[]
  usages        PromptUsage[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SavedPrompt {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  promptId      String
  prompt        Prompt    @relation(fields: [promptId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  
  @@unique([userId, promptId])
}

model PromptUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id])
  createdAt DateTime @default(now())
}

// Content: Resources
model Resource {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  category      String    // templates, scripts, frameworks, etc.
  
  downloadUrl   String?
  fileUrl       String?
  content       String?   @db.Text
  
  type          String    // notion, figma, pdf, etc.
  tags          String[]
  
  tier          String    @default("starter")
  published     Boolean   @default(false)
  
  downloads     Int       @default(0)
  saved         Int       @default(0)
  
  savedBy       SavedResource[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SavedResource {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  resourceId    String
  resource      Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  
  @@unique([userId, resourceId])
}

// AI Tools Database
model Tool {
  id            String    @id @default(cuid())
  name          String    @unique
  url           String
  slug          String    @unique
  description   String    @db.Text
  
  logo          String?
  pricingModel  String    // free, freemium, paid
  monthlyPrice  String?
  
  category      String
  categories    String[]
  incomeAngle   String?   @db.Text
  
  tutorials     String?   @db.Text
  workflows     String?   @db.Text
  
  rating        Float     @default(0)
  reviews       Int       @default(0)
  difficulty    String    @default("Beginner")

  published     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Learning & Progression
model Roadmap {
  id            String    @id @default(cuid())
  title         String
  description   String
  slug          String    @unique
  
  duration      Int       // days
  difficulty    String
  targetIncome  Int?

  milestones    Milestone[]
  
  published     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Milestone {
  id            String    @id @default(cuid())
  roadmapId     String
  roadmap       Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  
  day           Int
  title         String
  description   String    @db.Text
  
  order         Int
  createdAt     DateTime  @default(now())
}

model CompletedModule {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  moduleId      String
  moduleName    String
  
  completedAt   DateTime  @default(now())
  
  @@unique([userId, moduleId])
}

// Community & Gamification
model CommunityProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio           String?
  website       String?
  twitter       String?
  
  publicProfile Boolean   @default(true)
  
  wins          String[]
  incomeLastMonth Int?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channel       String    // wins, accountability, tools, etc.
  content       String    @db.Text
  
  reactions     String[]
  commentCount  Int       @default(0)
  
  isPinned      Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  unlockedAt    DateTime  @default(now())

  @@unique([userId, achievementId])
}

model Achievement {
  id            String    @id @default(cuid())
  title         String
  description   String
  icon          String
  xpReward      Int

  createdAt     DateTime  @default(now())
}

// Income Tracking
model IncomeEntry {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  source        String?
  playbookId    String?
  amount        Float
  date          DateTime  @default(now())
  notes         String?
  isPublic      Boolean   @default(true)

  createdAt     DateTime  @default(now())
}

// AI Interactions
model AIConversation {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages      Json      // Array of message objects

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Analytics
model Event {
  id            String    @id @default(cuid())
  userId        String?
  eventType     String    // page_view, prompt_used, resource_downloaded, etc.
  metadata      Json
  
  createdAt     DateTime  @default(now())
}

model ReferralBonus {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  reason      String
  amount      Int      // XP or Credits
  createdAt   DateTime @default(now())
}

model AnalyticsDashboard {
  id            String    @id @default(cuid())
  
  totalUsers    Int       @default(0)
  activeUsers   Int       @default(0)
  mrr           Int       @default(0)
  churnRate     Float     @default(0)
  
  date          DateTime  @unique
  createdAt     DateTime  @default(now())
}
